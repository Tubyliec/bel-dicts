<services>
  <service name="obs_scm">
    <param name="url">https://github.com/tubyliec/bel-dicts</param>
    <param name="scm">git</param>
    <param name="revision">refs/tags/v0.5.2</param>
    <param name="versionformat">@PARENT_TAG@</param>
    <param name="versionrewrite-pattern">v(.*)</param>
    <param name="extract">debian/changelog</param>
    <param name="extract">debian/control</param>
    <param name="extract">debian/copyright</param>
    <param name="extract">debian/rules</param>
  </service>
  <service name="tar" mode="buildtime"/>
  <service name="recompress" mode="buildtime">
    <param name="compression">gz</param>
    <param name="file">*.tar</param>
  </service>
  <service name="set_version" mode="buildtime"/>
</services>
